# =============================================================================
# AOA Financial — environment configuration
# Copy to `.env` and fill in secrets. NEVER commit a real `.env`.
#
# Load order (lowest → highest priority):
#   1. profiles/{AOA_PROFILE or AOA_ENV}.env
#   2. .env (this file)
#   3. Shell environment variables
#
# Quick start:
#   export AOA_PROFILE=paper-dry
#   cp .env.example .env   # add API keys
#   aoa doctor && aoa run
# =============================================================================

# --- Named environment -------------------------------------------------------
# test | paper-dry | paper | live
# Defaults: paper-dry (Alpaca paper + dry-run, no orders submitted)
AOA_ENV=paper-dry
# Optional alias for a profiles/*.env file (defaults to AOA_ENV when unset)
# AOA_PROFILE=paper-dry

# --- Anthropic (the reasoning engine for the swarm) -------------------------
ANTHROPIC_API_KEY=sk-ant-...
AOA_MODEL=claude-sonnet-4-20250514
# Effort level: low | medium | high | xhigh | max
AOA_EFFORT=high

# --- Alpaca brokerage credentials -------------------------------------------
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Usually derived from AOA_ENV; override only when you know what you are doing.
ALPACA_LIVE=false

# --- Live trading acknowledgement -------------------------------------------
# Required only when AOA_ENV=live
# AOA_LIVE_ACK=I_UNDERSTAND

# --- Runtime data paths -----------------------------------------------------
# Per-environment state lives under data/{AOA_ENV}/ by default.
AOA_DATA_DIR=data
# Explicit journal path (must match AOA_ENV). Profiles set this automatically.
AOA_JOURNAL_PATH=data/paper-dry/journal/aoa.jsonl

# --- Trading universe & cadence ---------------------------------------------
AOA_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL,META,SPY,QQQ
AOA_CYCLE_SECONDS=900

# --- Risk limits (hard guardrails) ------------------------------------------
AOA_MAX_POSITION_PCT=0.10
AOA_MAX_OPTIONS_PCT=0.15
AOA_MAX_DAILY_LOSS_PCT=0.03
AOA_MIN_CASH_BUFFER_PCT=0.05
AOA_MAX_ORDERS_PER_CYCLE=5

# --- Execution behavior ------------------------------------------------------
# Usually derived from AOA_ENV; paper-dry forces true, paper/live force false.
AOA_DRY_RUN=true

# --- News feed (Alpaca market-data headlines for FundamentalAgent) -----------
# "true" => fetch recent headlines from Alpaca when analyzing candidates.
AOA_NEWS_ENABLED=true

# --- Web dashboard & REST API -------------------------------------------------
AOA_WEB_HOST=0.0.0.0
AOA_WEB_PORT=8080
# "true" => start the background trading loop when running `aoa serve`.
AOA_WEB_AUTO_LOOP=false

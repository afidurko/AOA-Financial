# =============================================================================
# AOA Financial — environment configuration
# Copy to `.env` and fill in. NEVER commit a real .env.
# =============================================================================

# --- Anthropic (the reasoning engine for the swarm) -------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model used by the agents (defaults to claude-opus-4-8)
AOA_MODEL=claude-opus-4-8
# Effort level for agent reasoning: low | medium | high | xhigh | max
AOA_EFFORT=high

# --- Alpaca brokerage credentials -------------------------------------------
# The swarm auto-selects the LIVE endpoint when ALPACA_LIVE=true, otherwise the
# paper-trading sandbox. Live trading is enabled by default once live keys are
# present and ALPACA_LIVE=true. Risk guards still apply in every mode.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Set to "true" to route orders to the live brokerage (real money). Leave unset
# or "false" to use the paper-trading sandbox.
ALPACA_LIVE=false

# --- Trading universe & cadence ---------------------------------------------
# Comma-separated tickers the scanner is allowed to consider. Leave blank to let
# the scanner pull the broker's most-active list.
AOA_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL,META,SPY,QQQ
# Seconds between swarm cycles when running the continuous loop.
AOA_CYCLE_SECONDS=900

# --- Alpaca news feed (Fundamental agent) ------------------------------------
# Headlines fetched per symbol each cycle from Alpaca's Benzinga news API.
AOA_NEWS_LIMIT=5
# How far back (hours) to search for headlines.
AOA_NEWS_LOOKBACK_HOURS=72

# --- Risk limits (hard guardrails — orders violating these are blocked) ------
# Max fraction of total equity to allocate to a single new position (0.0–1.0).
AOA_MAX_POSITION_PCT=0.10
# Max fraction of equity deployable into options premium across the book.
AOA_MAX_OPTIONS_PCT=0.15
# Stop opening new positions once realized+unrealized loss for the day exceeds
# this fraction of starting equity (kill switch).
AOA_MAX_DAILY_LOSS_PCT=0.03
# Minimum cash buffer to keep settled/unencumbered (fraction of equity).
AOA_MIN_CASH_BUFFER_PCT=0.05
# Hard cap on number of orders the swarm may submit per cycle.
AOA_MAX_ORDERS_PER_CYCLE=5

# --- Execution behavior ------------------------------------------------------
# "true" => compute decisions but do NOT submit orders (audit only).
AOA_DRY_RUN=false

# =============================================================================
# AOA Financial — environment configuration
# Copy to `.env` and fill in secrets. NEVER commit a real `.env`.
#
# Load order (lowest → highest priority):
#   1. profiles/{AOA_PROFILE or AOA_ENV}.env
#   2. .env (this file)
#   3. Shell environment variables
#
# Quick start:
#   export AOA_PROFILE=paper-dry
#   cp .env.example .env   # add API keys
#   aoa doctor && aoa run
# =============================================================================

# --- Named environment -------------------------------------------------------
# test | paper-dry | paper | live
# Defaults: paper-dry (Alpaca paper + dry-run, no orders submitted)
AOA_ENV=paper-dry
# Optional alias for a profiles/*.env file (defaults to AOA_ENV when unset)
# AOA_PROFILE=paper-dry

# --- Anthropic (the reasoning engine for the swarm) -------------------------
ANTHROPIC_API_KEY=sk-ant-...
AOA_MODEL=claude-sonnet-4-6
# Effort level: low | medium | high | xhigh | max
AOA_EFFORT=high

# --- Broker (default: Moomoo via OpenD) ---------------------------------------
# moomoo | alpaca
AOA_BROKER=moomoo
# Moomoo OpenD gateway (install from https://www.moomoo.com/download/OpenAPI/)
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_MARKET=US
MOOMOO_SECURITY_FIRM=FUTUINC
# Paper/simulate vs live (usually derived from AOA_ENV)
MOOMOO_LIVE=false
# Required for live trading only — your Moomoo trading unlock password
MOOMOO_UNLOCK_PASSWORD=
# MOOMOO_ACC_ID=0
# MOOMOO_ACC_INDEX=0
# Setup: SETUP-AWAITING-YOU.md  |  helper: bash scripts/setup_moomoo_auth.sh

# --- Alpaca (optional — set AOA_BROKER=alpaca) -------------------------------
# Paper keys from https://alpaca.markets (Trading API PK..., not OAuth authx keys).
# OR skip these and run: alpaca profile login   (AOA reads ~/.config/alpaca/profiles/)
# pip install -e ".[alpaca]"  |  helper: bash scripts/setup_alpaca_auth.sh
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Also accepts Alpaca CLI env names: ALPACA_API_KEY + ALPACA_SECRET_KEY
# Auto-load Alpaca CLI OAuth/API-key profiles when .env keys are blank (default true)
# AOA_ALPACA_USE_CLI_PROFILE=true
# AOA_ALPACA_PROFILE=paper
# Usually derived from AOA_ENV; override only when you know what you are doing.
ALPACA_LIVE=false
# Optional market-data overrides for GET /v2/stocks/bars
# ALPACA_DATA_FEED=sip
# ALPACA_BAR_ADJUSTMENT=raw

# --- Live trading acknowledgement -------------------------------------------
# Required only when AOA_ENV=live
# AOA_LIVE_ACK=I_UNDERSTAND

# --- Runtime data paths -----------------------------------------------------
# Per-environment state lives under data/{AOA_ENV}/ by default.
AOA_DATA_DIR=data
# Explicit journal path (must match AOA_ENV). Profiles set this automatically.
AOA_JOURNAL_PATH=data/paper-dry/journal/aoa.jsonl
# Daily-loss baseline + settlement ledger (kill-switch persistence, T+1 cash).
AOA_STATE_PATH=data/paper-dry/state.json

# --- Trading universe & cadence ---------------------------------------------
AOA_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL,META,SPY,QQQ
AOA_CYCLE_SECONDS=900

# --- Alpaca news feed (Fundamental agent) ------------------------------------
# Headlines fetched per symbol each cycle from Alpaca's Benzinga news API.
AOA_NEWS_LIMIT=5
# How far back (hours) to search for headlines.
AOA_NEWS_LOOKBACK_HOURS=72

# --- Multi-timeframe historical bars (Alpaca) -------------------------------
# Comma-separated bar intervals fetched each cycle. Defaults cover 1m, 3m, 5m,
# 15m, 1h, daily, and yearly (12Month) context. Aliases: 1D, 1H, 1Year.
# AOA_BAR_TIMEFRAMES=1Min,3Min,5Min,15Min,1Hour,1Day,12Month
# Alpaca data feed for quotes/bars: iex (free tier) | sip (full US exchanges)
AOA_BAR_FEED=iex

# --- Risk limits (hard guardrails — orders violating these are blocked) ------
# Max fraction of total equity to allocate to a single new position (0.0–1.0).
AOA_MAX_POSITION_PCT=0.10
AOA_MAX_OPTIONS_PCT=0.15
AOA_MAX_DAILY_LOSS_PCT=0.03
AOA_MIN_CASH_BUFFER_PCT=0.05
AOA_MAX_ORDERS_PER_CYCLE=5

# --- Swarm pipeline ----------------------------------------------------------
# Parallel workers for per-symbol analysis (technical + fundamental). Set to 1
# for fully sequential execution.
AOA_PARALLEL_WORKERS=4

# --- Neuroplasticity (journal → memory → agent context) ----------------------
# "true" => distill lessons from the journal and inject into portfolio/risk.
AOA_PLASTICITY_ENABLED=true
# How many recent journal lines to scan when consolidating memory.
AOA_PLASTICITY_TAIL=200
# Maximum episodic lessons kept in durable memory.
AOA_PLASTICITY_MAX_LESSONS=10

# --- Work loop (discover → learn → approve → verify → merge) -----------------
# Autonomous improvement cycle for materials, adaptations, and code changes.
AOA_WORKLOOP_ENABLED=true
# Human approver required before execute/merge (default: Aaron).
AOA_WORKLOOP_APPROVER=Aaron
# Human user approver when Aaron escalates sensitive or large changes.
AOA_WORKLOOP_USER_APPROVER=user
# "true" => Bob/Julie/Alan/Aaron review proposed diffs before the approval gate.
AOA_WORKLOOP_TEAM_REVIEW_ENABLED=true
# Escalate to user when this many files change in one proposal.
AOA_WORKLOOP_ESCALATION_FILE_THRESHOLD=12
# Journal lines scanned when extracting learning signals.
AOA_WORKLOOP_JOURNAL_TAIL=100
# Lessons/adaptations retained in data/{AOA_ENV}/workloop/learnings.json
AOA_WORKLOOP_MAX_LESSONS=20
# "true" => git commit approved changes during execute stage.
AOA_WORKLOOP_AUTO_COMMIT=false
# "true" => merge feature branch into main after double verification.
AOA_WORKLOOP_ALLOW_MERGE=false
# Base branch for merge stage.
AOA_WORKLOOP_BASE_BRANCH=main
# Seconds between completed work loops (next cycle picks up fresh learnings).
AOA_WORKLOOP_INTERVAL_SECONDS=3600

# --- Fable 5 repair loop (discover → worktree → minimal-fix → verifier) ---------
AOA_REPAIR_ENABLED=true
# Rewrite STATE.md when running aoa repair triage
AOA_REPAIR_SYNC_STATE=true
# Queue + run log under data/{AOA_ENV}/repair/
# AOA_REPAIR_PATH=
# Git worktrees for isolated fixes (gitignored)
AOA_REPAIR_WORKTREES_DIR=.aoa-worktrees

# --- TradingAgents framework (arXiv:2412.20138) ------------------------------
# Built-in AOA swarm: four-analyst team, bull/bear research, risk debate, fund manager.
AOA_TRADING_AGENTS_ENABLED=true
AOA_TRADING_AGENTS_DEBATE_ROUNDS=1

# --- Upstream TradingAgents library v0.3.0 (optional) ------------------------
# Install: pip install -e ".[tradingagents]"  (see requirements-tradingagents.txt)
# Changelog: docs/tradingagents/CHANGELOG.md
# Historical propagate: python scripts/tradingagents_propagate.py NVDA 2024-05-10
# Indicator benchmark: python scripts/test_yfinance_indicators.py AAPL macd 2024-11-01
# TRADINGAGENTS_* overrides DEFAULT_CONFIG (see upstream changelog for full list).
# TRADINGAGENTS_LLM_PROVIDER=anthropic
# TRADINGAGENTS_DEEP_THINK_LLM=claude-opus-4-7
# TRADINGAGENTS_QUICK_THINK_LLM=claude-opus-4-7
# TRADINGAGENTS_ANTHROPIC_EFFORT=high
# TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
# TRADINGAGENTS_MAX_RISK_ROUNDS=1
# Optional comma-separated extra learning sources (paths).
# AOA_WORKLOOP_EXTRA_SOURCES=docs/,notes/

# --- Execution behavior ------------------------------------------------------
# Usually derived from AOA_ENV; paper-dry forces true, paper/live force false.
AOA_DRY_RUN=true

# --- News feed (Alpaca market-data headlines for FundamentalAgent) -----------
# "true" => fetch recent headlines from Alpaca when analyzing candidates.
AOA_NEWS_ENABLED=true

# --- Web dashboard & REST API -------------------------------------------------
AOA_WEB_HOST=0.0.0.0
AOA_WEB_PORT=8080
# "true" => start the background trading loop when running `aoa serve`.
AOA_WEB_AUTO_LOOP=false
# Optional link to a local OpenStock instance (header shortcut in dashboard).
# AOA_OPENSTOCK_URL=http://localhost:3000

# --- Obsidian second brain (optional sibling clone) ---------------------------
# Path to your Obsidian vault (created by ./scripts/obsidian-second-brain-setup.sh).
# AOA_OBSIDIAN_VAULT_PATH=./AOA-Vault
# Optional: override the skill repo clone URL or directory.
# OBSIDIAN_SECONDBRAIN_REPO=https://github.com/afidurko/obsidian-second-brain.git
# OBSIDIAN_SECONDBRAIN_DIR=./obsidian-second-brain
# Bridge research keys into ~/.config/obsidian-second-brain/.env via sync script:
# GEMINI_API_KEY=, PERPLEXITY_API_KEY=, XAI_API_KEY=, YOUTUBE_API_KEY=

# --- OpenStock integration (optional sibling clone) ---------------------------
# Shared Finnhub key for aoa_financial fundamentals and OpenStock market data.
# FINNHUB_API_KEY=
# Docker overlay ports when using docker-compose.openstock.yml
# OPENSTOCK_PORT=3000
# OPENSTOCK_MONGO_PORT=27017

# --- Analytics, notifications, workflow -------------------------------------
# SQLite path defaults to data/{AOA_ENV}/analytics/aoa.sqlite
# AOA_ANALYTICS_DB_PATH=
AOA_ANALYTICS_ENABLED=true
AOA_TEAM_PARALLEL=true
AOA_NOTIFY_PUSH_OPPORTUNITIES=true
AOA_NOTIFY_PUSH_HALTS=true
AOA_NOTIFY_MIN_CONVICTION=0.65
# Optional smart cadence (0 = use AOA_CYCLE_SECONDS always)
# AOA_CYCLE_SECONDS_MARKET_OPEN=300
# AOA_CYCLE_SECONDS_MARKET_CLOSED=3600

# --- Scholar research (Semantic Scholar; user approval in dashboard) ----------
AOA_SCHOLAR_ENABLED=true
AOA_SCHOLAR_QUERY=algorithmic trading momentum portfolio optimization
AOA_SCHOLAR_MAX_RESULTS=5

# --- Aaron CEO alerts (iPhone push — never email) ----------------------------
# Option A (recommended): your custom iPhone app — POST alerts to your backend.
# Your server forwards to APNs and delivers to the app on the user's iPhone.
AOA_CUSTOM_APP_WEBHOOK_URL=https://your-server.example.com/aoa/alerts
# Optional bearer token your webhook validates:
AOA_CUSTOM_APP_API_KEY=
# Optional device id to route alerts to a specific iPhone installation:
AOA_CUSTOM_APP_DEVICE_ID=
#
# Option B: Pushover (https://pushover.net) — install the app on your iPhone.
AOA_PUSHOVER_USER_KEY=
AOA_PUSHOVER_APP_TOKEN=
# Option C: ntfy (https://ntfy.sh or self-hosted) — install the ntfy app on iPhone.
# AOA_NTFY_TOPIC=aoa-financial-alerts
# AOA_NTFY_SERVER=https://ntfy.sh
AOA_NTFY_TOPIC=
AOA_NTFY_SERVER=https://ntfy.sh

# --- Low-rank signal adaptation (LoRA-style online recalibration) ------------
# When enabled, a tiny trainable low-rank adapter recalibrates each agent's raw
# conviction and learns across cycles from each symbol's realized return. It
# starts as a no-op and only departs from the agents' output as it learns.
AOA_ADAPT_ENABLED=false
# Where the learned adapter state is persisted (JSON).
AOA_ADAPT_PATH=.aoa/signal_adapter.json
# Low-rank hyperparameters and online learning rate.
AOA_ADAPT_RANK=4
AOA_ADAPT_ALPHA=8.0
AOA_ADAPT_LR=0.05

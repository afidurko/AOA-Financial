# OpenStock environment — copy to OpenStock/.env
# Or run: ./scripts/sync-openstock-env.sh (bridges from AOA .env)
#
# Upstream docs: OpenStock/README.md#environment-variables

NODE_ENV=development

# Local MongoDB (docker-compose.openstock.yml)
MONGODB_URI=mongodb://root:example@localhost:27017/openstock?authSource=admin

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Finnhub — sync script maps FINNHUB_API_KEY from AOA .env
NEXT_PUBLIC_FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# AI + automation (optional for UI-only dev)
GEMINI_API_KEY=
INNGEST_SIGNING_KEY=dev-placeholder

# Email (optional for local dev)
NODEMAILER_EMAIL=
NODEMAILER_PASSWORD=

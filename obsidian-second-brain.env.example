# obsidian-second-brain — research toolkit credentials
# Generated by ./scripts/sync-obsidian-second-brain-env.sh from AOA .env
# Target: ~/.config/obsidian-second-brain/.env (permissions 600)

# ─── Vault location (required) ──────────────────────────────
OBSIDIAN_VAULT_PATH=

# ─── xAI Grok ───────────────────────────────────────────────
# Powers /x-read and /x-pulse (live X reading + trend analysis)
XAI_API_KEY=

# ─── Perplexity ─────────────────────────────────────────────
# Powers /research and /research-deep
PERPLEXITY_API_KEY=

# ─── Google Gemini ──────────────────────────────────────────
# Powers /notebooklm (vault-grounded synthesis)
GEMINI_API_KEY=

# ─── YouTube Data API v3 (optional) ─────────────────────────
YOUTUBE_API_KEY=

# ─── Model defaults (override if desired) ───────────────────
GROK_MODEL=grok-4
PERPLEXITY_RESEARCH_MODEL=sonar-pro
PERPLEXITY_DEEP_MODEL=sonar-deep-research
NOTEBOOKLM_MODEL=gemini-2.5-flash

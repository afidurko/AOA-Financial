# Alpaca paper sandbox — real paper orders enabled.
AOA_ENV=paper
AOA_DRY_RUN=false
ALPACA_LIVE=false
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/paper/journal/aoa.jsonl
# Online LoRA-style conviction calibration from realized outcomes
AOA_ADAPT_ENABLED=true
AOA_ADAPT_PATH=data/paper/signal_adapter.json

# Paper sandbox — real paper orders enabled.
AOA_ENV=paper
AOA_DRY_RUN=false
ALPACA_LIVE=false
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/paper/journal/aoa.jsonl
# Online LoRA-style conviction calibration from realized outcomes
AOA_ADAPT_ENABLED=true
AOA_ADAPT_PATH=data/paper/signal_adapter.json

# Swarm memory stack (plasticity + study cortex + TradingAgents) — always on
AOA_PLASTICITY_ENABLED=true
AOA_STUDY_USAGE_ENABLED=true
AOA_STUDY_USAGE_BASELINE=true
AOA_STUDY_USAGE_LIMIT=8
AOA_TRADING_AGENTS_ENABLED=true
AOA_PARALLEL_WORKERS=4

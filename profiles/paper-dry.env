# Paper sandbox — analyze and journal only (recommended starting point).
AOA_ENV=paper-dry
AOA_BROKER=moomoo
AOA_DRY_RUN=true
MOOMOO_LIVE=false
ALPACA_LIVE=false
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/paper-dry/journal/aoa.jsonl
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111

# Swarm memory stack (plasticity + study cortex + TradingAgents)
AOA_PLASTICITY_ENABLED=true
AOA_STUDY_USAGE_ENABLED=true
AOA_STUDY_USAGE_LIMIT=8
AOA_TRADING_AGENTS_ENABLED=true
AOA_PARALLEL_WORKERS=4

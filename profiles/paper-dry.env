# Moomoo paper dry-run — analyze and journal only (default; no orders submitted).
# Local Ollama LLM; no cloud API key required (pip install -e ".[openai]").
AOA_ENV=paper-dry
AOA_BROKER=moomoo
AOA_DRY_RUN=true
MOOMOO_LIVE=false
ALPACA_LIVE=false
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
AOA_LLM_PROVIDER=ollama
AOA_MODEL=llama3.1
AOA_TRADING_AGENTS_ENABLED=false
AOA_AUTO_ACTIVATE=true
# AOA_WEB_AUTO_LOOP=true
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/paper-dry/journal/aoa.jsonl

# Moomoo paper via OpenD — simulate orders (not dry-run).
AOA_ENV=paper
AOA_BROKER=moomoo
AOA_DRY_RUN=false
MOOMOO_LIVE=false
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/paper/journal/aoa.jsonl
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
AOA_ADAPT_ENABLED=true
AOA_ADAPT_PATH=data/paper/signal_adapter.json

# Swarm memory stack (plasticity + study cortex + TradingAgents)
AOA_PLASTICITY_ENABLED=true
AOA_STUDY_USAGE_ENABLED=true
AOA_STUDY_USAGE_LIMIT=8
AOA_TRADING_AGENTS_ENABLED=true
AOA_PARALLEL_WORKERS=4

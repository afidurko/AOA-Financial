# Moomoo + local Ollama — log into OpenD, then: aoa activate
# No cloud API keys. Paper dry-run by default (no orders submitted).
AOA_ENV=paper-dry
AOA_BROKER=moomoo
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
AOA_LLM_PROVIDER=ollama
AOA_MODEL=llama3.1
AOA_DRY_RUN=true
AOA_TRADING_AGENTS_ENABLED=false

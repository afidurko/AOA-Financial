# Live brokerage — real money. Copy to .env and add credentials; never commit secrets.
AOA_ENV=live
AOA_DRY_RUN=false
ALPACA_LIVE=true
AOA_LIVE_ACK=I_UNDERSTAND
AOA_DATA_DIR=data
AOA_JOURNAL_PATH=data/live/journal/aoa.jsonl

# Swarm memory — always on (same as paper)
AOA_PLASTICITY_ENABLED=true
AOA_STUDY_USAGE_ENABLED=true
AOA_STUDY_USAGE_BASELINE=true
AOA_STUDY_USAGE_LIMIT=8
AOA_TRADING_AGENTS_ENABLED=true
